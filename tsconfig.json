{
  "compilerOptions": {
    /* === 基本設定 === */
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,

    /* === モジュール関連 === */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* === Next.js 推奨 === */
    "incremental": true,
    "plugins": [{ "name": "next" }],

    /* === パスエイリアス === */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    /* === 追加（これが今回の対応） === */
    "ignoreDeprecations": "5.0",

    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}